{
  "manifest_version": 2,
  "name": "Perfect Canvas",
  "version": "0.1.0",
  "description": "Frame-perfect WebGL canvas capture to FFmpeg",
  "browser_specific_settings": {
    "gecko": {
      "id": "perfect-canvas@localhost",
      "data_collection_permissions": {
        "required": [
          "websiteContent",
          "websiteActivity"
        ],
        "optional": []
      }
    }
  },
  "permissions": [
    "nativeMessaging",
    "activeTab",
    "tabs",
    "http://127.0.0.1/*",
    "ws://127.0.0.1/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_title": "Perfect Canvas"
  },
  "content_scripts": [
    {
      "matches": [
        "https://hydra.ojack.xyz/*",
        "https://cables.gl/*",
        "https://sandbox.cables.gl/*",
        "https://editor.p5js.org/*",
        "https://www.shadertoy.com/*",
        "https://strudel.cc/*",
        "*://localhost/*"
      ],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": ["inject.js"]
}
